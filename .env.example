# General Django settings
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=change-this-secret-key
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_LANGUAGE_CODE=en-us
DJANGO_TIME_ZONE=UTC
DJANGO_USE_I18N=true
DJANGO_USE_TZ=true
DJANGO_STATIC_URL=/static/
DJANGO_LOGIN_REDIRECT_URL=/
DJANGO_LOGOUT_REDIRECT_URL=/

# Contact email settings
# DEFAULT_FROM_EMAIL is the sender address used by Django.
# NOTIFY_EMAIL is the destination inbox that receives messages from the contact form.
DJANGO_DEFAULT_FROM_EMAIL=no-reply@example.com
DJANGO_NOTIFY_EMAIL=admin@example.com

# Email backend
# For local development, the console backend prints emails in the app logs instead of sending them.
# To send real emails, use: django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# SMTP server settings
# Common examples:
# Gmail: smtp.gmail.com / port 587 / TLS=true / SSL=false
# Outlook 365: smtp.office365.com / port 587 / TLS=true / SSL=false
DJANGO_EMAIL_HOST=
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=
# Put your SMTP password or app password here.
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_EMAIL_USE_TLS=true
DJANGO_EMAIL_USE_SSL=false
DJANGO_EMAIL_TIMEOUT=10

# Database and container settings
# For local execution, use a writable path in your machine, for example:
# SQLITE_PATH=/absolute/path/to/PW-ProductivitySite/ProductivitySite/db.sqlite3
# Docker Compose overrides this value and uses /data/db.sqlite3 inside the container.
SQLITE_PATH=/absolute/path/to/PW-ProductivitySite/ProductivitySite/db.sqlite3
APP_PORT=8080
